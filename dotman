#!/usr/bin/env bash
set -euo pipefail

# dotman - 自用 dotfiles 管理脚本
# 模型：真实文件保存在 Git 仓库，本机通过软链引用仓库中的文件/目录。

VERSION="0.3.0"

# ---------- 全局默认配置 ----------
readonly DOTMAN_HOME="${DOTMAN_HOME:-${HOME}/.dotman}"
readonly DOTMAN_REPO_DEFAULT="${DOTMAN_HOME}/dotfiles"
readonly DOTMAN_REPO="${DOTMAN_REPO:-$DOTMAN_REPO_DEFAULT}"
readonly DOTMAN_CONFIG_DIR="${HOME}/.config/dotman"
readonly CONFIG_FILE="config.conf"
readonly LINKS_COMMON="links.common.conf"
readonly LINKS_PREFIX="links."
readonly DATE_FMT=".%Y%m%d%H%M%S.bak"

# ---------- 颜色 ----------
readonly C_RED=$'\033[31m'
readonly C_GREEN=$'\033[32m'
readonly C_YELLOW=$'\033[33m'
readonly C_CYAN=$'\033[36m'
readonly C_BLUE=$'\033[34m'
readonly C_BOLD=$'\033[1m'
readonly C_RESET=$'\033[0m'

err()  { echo "${C_RED}[!]${C_RESET} $*" >&2; }
warn() { echo "${C_YELLOW}[~]${C_RESET} $*"; }
ok()   { echo "${C_GREEN}[✓]${C_RESET} $*"; }
info() { echo "${C_CYAN}[i]${C_RESET} $*"; }

# ---------- 依赖 ----------
need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    err "缺少必要命令: $1"
    exit 1
  fi
}

check_deps() {
  need_cmd git
}

# ---------- 路径 ----------
# 优先级：显式 DOTMAN_REPO 环境变量 > 本地 config > 默认
repo_root() {
  if [[ -n "${DOTMAN_REPO:-}" && "$DOTMAN_REPO" != "$DOTMAN_REPO_DEFAULT" ]]; then
    echo "$DOTMAN_REPO"
    return 0
  fi
  local cfg="${DOTMAN_CONFIG_DIR}/${CONFIG_FILE}"
  if [[ -f "$cfg" ]]; then
    local rp
    rp=$(ini_get_value "$cfg" "" "repo_path")
    if [[ -n "$rp" ]]; then
      echo "$rp"
      return 0
    fi
  fi
  echo "$DOTMAN_REPO_DEFAULT"
}

# hostname 只从本地配置读取，不提交到仓库，避免多机器混淆
hostname_from_config() {
  local cfg="${DOTMAN_CONFIG_DIR}/${CONFIG_FILE}"
  if [[ -f "$cfg" ]]; then
    local h
    h=$(ini_get_value "$cfg" "" "hostname")
    if [[ -n "$h" ]]; then
      echo "$h"
      return 0
    fi
  fi
  hostname -s
}

current_hostname() {
  hostname_from_config
}

# ---------- 路径展开 ----------
# 路径规则：
#   - 以 ~ 开头：展开为 $HOME
#   - 以 / 开头：绝对路径，直接使用
#   - 其它相对路径：默认相对于 $HOME（如 bin -> ~/bin，./bin -> ~/bin）
expand_path() {
  local p="$1"
  if [[ "$p" == "~"* ]]; then
    p="${p/#\~/$HOME}"
  elif [[ "$p" != /* ]]; then
    p="$HOME/$p"
  fi
  # 规范化 ./ 和末尾的 /.
  p=$(printf '%s' "$p" | sed 's|/\./|/|g; s|/\.$||')
  echo "$p"
}

relative_home() {
  local p="$1"
  if [[ "$p" == "$HOME"* ]]; then
    echo "~${p#$HOME}"
  else
    echo "$p"
  fi
}

home_relative_path() {
  local p="$1"
  if [[ "$p" != "$HOME"* ]]; then
    echo ""
    return 0
  fi
  local r="${p#$HOME}"
  r="${r#/}"
  r="${r#./}"
  echo "$r"
}

# ---------- INI 读写（纯 Shell） ----------

# ini_get_value <file> <section> <key>
# section 为空时表示顶层（无 section header 的 key=value）
ini_get_value() {
  local file="$1" section="$2" key="$3"
  if [[ ! -f "$file" ]]; then
    return 0
  fi
  awk -v section="$section" -v key="$key" '
    BEGIN { in_section = (section == "") ? 1 : 0 }
    /^\[.*\]/ {
      cur = substr($0, 2, length($0) - 2)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", cur)
      in_section = (cur == section)
      next
    }
    /^[[:space:]]*$/ { next }
    /^[#;]/ { next }
    in_section {
      eq = index($0, "=")
      if (eq == 0) next
      k = substr($0, 1, eq - 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
      if (k == key) {
        v = substr($0, eq + 1)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
        # 去掉首尾引号
        if (v ~ /^".*"$/) v = substr(v, 2, length(v) - 2)
        else if (v ~ /^'.*'$/) v = substr(v, 2, length(v) - 2)
        print v
        exit
      }
    }
  ' "$file"
}

# ini_set_value <file> <section> <key> <value>
# 如果 key 已存在则更新，不存在则追加
ini_set_value() {
  local file="$1" section="$2" key="$3" value="$4"

  if [[ ! -f "$file" ]]; then
    # 新文件
    {
      if [[ -n "$section" ]]; then
        printf '[%s]\n' "$section"
      fi
      printf '%s = "%s"\n' "$key" "$value"
    } > "$file"
    return 0
  fi

  local tmp="${file}.tmp"

  awk -v section="$section" -v key="$key" -v value="$value" '
    BEGIN { in_section = (section == "") ? 1 : 0; found = 0; seen = 0 }
    /^\[.*\]/ {
      cur = substr($0, 2, length($0) - 2)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", cur)
      if (cur == section) {
        in_section = 1
        seen = 1
      } else {
        if (in_section && !found) {
          print key " = \"" value "\""
          found = 1
        }
        in_section = 0
      }
      print
      next
    }
    /^[[:space:]]*$/ { print; next }
    /^[#;]/ { print; next }
    in_section {
      eq = index($0, "=")
      if (eq == 0) { print; next }
      k = substr($0, 1, eq - 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
      if (k == key) {
        print key " = \"" value "\""
        found = 1
        next
      }
      print
      next
    }
    { print }
    END {
      if (!found) {
        if (!seen && section != "") {
          print "[" section "]"
        }
        print key " = \"" value "\""
      }
    }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
}

# ini_delete_key <file> <section> <key>
ini_delete_key() {
  local file="$1" section="$2" key="$3"
  if [[ ! -f "$file" ]]; then
    return 0
  fi
  local tmp="${file}.tmp"
  awk -v section="$section" -v key="$key" '
    BEGIN { in_section = (section == "") ? 1 : 0 }
    /^\[.*\]/ {
      cur = substr($0, 2, length($0) - 2)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", cur)
      in_section = (cur == section)
      print
      next
    }
    in_section {
      eq = index($0, "=")
      if (eq == 0) { print; next }
      k = substr($0, 1, eq - 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
      if (k == key) next
    }
    { print }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
}

# ini_ensure_links_file <path>
ini_ensure_links_file() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    cat > "$path" <<'EOF'
[links]

EOF
  fi
}

# ini_add_link <file> <src> <dst>
ini_add_link() {
  local file="$1" src="$2" dst="$3"
  ini_ensure_links_file "$file"
  ini_set_value "$file" "links" "$src" "$dst"
}

# ini_remove_link <file> <src>
ini_remove_link() {
  local file="$1" src="$2"
  ini_delete_key "$file" "links" "$src"
}

# ini_load_links <repo> <host>
# 输出: src<TAB>dst（合并 host 和 common 文件，host 优先）
ini_load_links() {
  local repo="$1" host="$2"
  local host_file="${repo}/${LINKS_PREFIX}${host}.conf"
  local common_file="${repo}/${LINKS_COMMON}"

  parse_links() {
    awk '
      /^\[links\]/ { in_links=1; next }
      /^\[.*\]/    { in_links=0; next }
      /^[[:space:]]*$/ { next }
      /^[#;]/ { next }
      in_links && /=/ {
        eq = index($0, "=")
        k = substr($0, 1, eq - 1)
        v = substr($0, eq + 1)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
        if (v ~ /^".*"$/) v = substr(v, 2, length(v) - 2)
        else if (v ~ /^'.*'$/) v = substr(v, 2, length(v) - 2)
        printf "%s\t%s\n", k, v
      }
    ' "$1"
  }

  # common 先输出，host 后输出，awk 去重保留后出现的（host 覆盖 common）
  {
    [[ -f "$common_file" ]] && parse_links "$common_file"
    [[ -f "$host_file" ]] && parse_links "$host_file"
  } | awk -F'\t' '!seen[$1]++'
}

# ini_find_src_by_dst <repo> <host> <dst>
ini_find_src_by_dst() {
  local repo="$1" host="$2" dst="$3"
  local files=(
    "${repo}/${LINKS_PREFIX}${host}.conf"
    "${repo}/${LINKS_COMMON}"
  )
  for f in "${files[@]}"; do
    if [[ -f "$f" ]]; then
      local result
      result=$(awk -v dst="$dst" '
        /^\[links\]/ { in_links=1; next }
        /^\[.*\]/    { in_links=0; next }
        /^[[:space:]]*$/ { next }
        /^[#;]/ { next }
        in_links && /=/ {
          eq = index($0, "=")
          k = substr($0, 1, eq - 1)
          v = substr($0, eq + 1)
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
          if (v ~ /^".*"$/) v = substr(v, 2, length(v) - 2)
          else if (v ~ /^'.*'$/) v = substr(v, 2, length(v) - 2)
          if (v == dst) { print k; exit }
        }
      ' "$f")
      if [[ -n "$result" ]]; then
        echo "$result"
        return 0
      fi
    fi
  done
}

# ini_delete_by_dst <repo> <host> <dst>
# 从 host 和 common 文件中删除 dst 对应的条目
ini_delete_by_dst() {
  local repo="$1" host="$2" dst="$3"
  local files=(
    "${repo}/${LINKS_PREFIX}${host}.conf"
    "${repo}/${LINKS_COMMON}"
  )
  for f in "${files[@]}"; do
    if [[ -f "$f" ]]; then
      local src
      src=$(awk -v dst="$dst" '
        /^\[links\]/ { in_links=1; next }
        /^\[.*\]/    { in_links=0; next }
        /^[[:space:]]*$/ { next }
        /^[#;]/ { next }
        in_links && /=/ {
          eq = index($0, "=")
          k = substr($0, 1, eq - 1)
          v = substr($0, eq + 1)
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
          if (v ~ /^".*"$/) v = substr(v, 2, length(v) - 2)
          else if (v ~ /^'.*'$/) v = substr(v, 2, length(v) - 2)
          if (v == dst) { print k; exit }
        }
      ' "$f")
      if [[ -n "$src" ]]; then
        ini_delete_key "$f" "links" "$src"
      fi
    fi
  done
}

repo_has_git() {
  local repo
  repo=$(repo_root)
  [[ -d "${repo}/.git" ]]
}

# ---------- Git 操作 ----------
git_dot() {
  local repo
  repo=$(repo_root)
  git -C "$repo" "$@"
}

auto_commit_push() {
  local msg="${1:-dotman update}"
  if [[ -z "$(git_dot status --porcelain)" ]]; then
    info "没有改动需要提交"
    return 0
  fi
  git_dot add -A
  git_dot commit -m "$msg"
  if ! git_dot push; then
    warn "git push 失败，已提交到本地，请检查网络或远程仓库后手动 push"
  fi
}

# ---------- 文件/软链操作 ----------
backup_item() {
  local target="$1"
  if [[ ! -e "$target" && ! -L "$target" ]]; then
    return 0
  fi
  local backup="${target}$(date +${DATE_FMT})"
  cp -a "$target" "$backup"
  ok "已备份到 $backup"
}

ensure_parent() {
  local path="$1"
  local dir
  dir=$(dirname "$path")
  [[ -d "$dir" ]] || mkdir -p "$dir"
}

is_symlink() {
  [[ -L "$1" ]]
}

symlink_points_to() {
  local link="$1" target="$2"
  local real
  real=$(readlink "$link")
  [[ "$real" == "$target" ]]
}

make_link() {
  local src="$1" dst="$2"
  ensure_parent "$dst"
  ln -sfn "$src" "$dst"
  fix_link_permissions "$src" "$dst"
}

is_ssh_private_key() {
  local path="$1"
  local name
  name=$(basename "$path")
  case "$name" in
    id_ed25519|id_rsa|id_ecdsa|id_dsa|id_ed25519_sk|id_ecdsa_sk)
      return 0 ;;
  esac
  if [[ -f "$path" ]]; then
    local first
    first=$(head -n 1 "$path" 2>/dev/null || true)
    if [[ "$first" == "-----BEGIN OPENSSH PRIVATE KEY-----" ]] || \
       [[ "$first" =~ ^-----BEGIN\ .*PRIVATE\ KEY-----$ ]]; then
      return 0
    fi
  fi
  return 1
}

is_safe_ssh_file() {
  local path="$1"
  local name
  name=$(basename "$path")
  case "$name" in
    *.pub|config|known_hosts|authorized_keys)
      return 0 ;;
  esac
  return 1
}

is_managed_by_dotman() {
  local path="$1"
  local repo
  repo=$(repo_root)
  local host
  host=$(current_hostname)
  local rel_path
  rel_path=$(relative_home "$path")
  [[ -n "$(ini_find_src_by_dst "$repo" "$host" "$rel_path")" ]]
}

is_binary_file() {
  local path="$1"
  local name
  name=$(basename "$path")

  # 按后缀快速判断常见二进制/数据文件
  case "$name" in
    *.db|*.sqlite|*.sqlite3|*.bak|*.zip|*.gz|*.tar|*.tgz|*.bz2|\
    *.7z|*.rar|*.jpg|*.jpeg|*.png|*.gif|*.bmp|*.webp|*.svgz|\
    *.mp3|*.mp4|*.avi|*.mov|*.mkv|*.wav|*.flac|*.ogg|\
    *.pdf|*.doc|*.docx|*.xls|*.xlsx|*.ppt|*.pptx|\
    *.exe|*.dll|*.so|*.dylib|*.bin|*.dat|*.dmg|*.pkg|\
    *.pyc|*.pyo|*.class|*.o|*.a|*.obj)
      return 0 ;;
  esac

  if [[ ! -f "$path" ]]; then
    return 1
  fi

  # 优先使用 file 命令
  if command -v file >/dev/null 2>&1; then
    local enc
    enc=$(file --mime-encoding -b "$path" 2>/dev/null || true)
    if [[ "$enc" == "binary" ]]; then
      return 0
    fi
  fi

  # 兜底：grep -I 能匹配到可打印字符就不是二进制
  if grep -qI . "$path" 2>/dev/null; then
    return 1
  fi
  return 0
}

is_log_file() {
  local path="$1"
  local name
  name=$(basename "$path")
  case "$name" in
    *.log)
      return 0 ;;
  esac
  return 1
}

# 返回文件类型标签：binary / log / text / 含二进制 / 目录
file_type_label() {
  local path="$1"
  if [[ -d "$path" ]]; then
    if [[ -n "$(scan_binary_files "$path")" ]]; then
      echo "含二进制"
    else
      echo "目录"
    fi
    return 0
  fi
  if is_binary_file "$path"; then
    echo "二进制"
  elif is_log_file "$path"; then
    echo "日志"
  else
    echo "文本"
  fi
}

scan_binary_files() {
  local target="$1"
  if [[ -f "$target" ]]; then
    if is_binary_file "$target" || is_log_file "$target"; then
      echo "$target"
    fi
    return 0
  fi
  if [[ ! -d "$target" ]]; then
    return 0
  fi

  local count=0
  local file
  while IFS= read -r -d '' file; do
    if is_binary_file "$file" || is_log_file "$file"; then
      echo "$file"
      count=$((count + 1))
      if [[ $count -ge 1000 ]]; then
        warn "扫描到超过 1000 个二进制/日志文件，停止扫描"
        break
      fi
    fi
  done < <(find "$target" -type f ! -name ".*" -print0 2>/dev/null || true)
}

# 将规则写入仓库根目录 .gitignore，避免重复
add_to_gitignore() {
  local pattern="$1"
  local repo
  repo=$(repo_root)
  local gitignore="${repo}/.gitignore"

  if [[ -f "$gitignore" ]] && grep -qxF "$pattern" "$gitignore" 2>/dev/null; then
    return 0
  fi

  ensure_parent "$gitignore"
  if [[ -f "$gitignore" ]] && [[ -s "$gitignore" ]]; then
    echo "" >> "$gitignore"
  fi
  echo "$pattern" >> "$gitignore"
  ok "已添加到 .gitignore：$pattern"
}

fix_link_permissions() {
  local src="$1" dst="$2"
  local name
  name=$(basename "$src")

  case "$name" in
    id_ed25519|id_rsa|id_ecdsa|id_dsa|id_ed25519_sk|id_ecdsa_sk|*.pem|*.key)
      if [[ -e "$dst" ]]; then
        chmod 600 "$dst" 2>/dev/null || true
      fi
      ;;
    config)
      if [[ -e "$dst" ]] && [[ "$(basename "$(dirname "$dst")")" == ".ssh" ]]; then
        chmod 600 "$dst" 2>/dev/null || true
      fi
      ;;
    known_hosts|authorized_keys|*.pub)
      if [[ -e "$dst" ]]; then
        chmod 644 "$dst" 2>/dev/null || true
      fi
      ;;
  esac
}

remove_sockets_from_backup() {
  local backup="$1"
  if [[ ! -d "$backup" ]]; then
    return 0
  fi
  local socket
  while IFS= read -r -d '' socket; do
    rm -f "$socket"
    warn "备份中跳过 Unix socket: $(relative_home "$socket" 2>/dev/null || echo "$socket")"
  done < <(find "$backup" -type s -print0 2>/dev/null || true)
}

backup_item() {
  local target="$1"
  if [[ ! -e "$target" && ! -L "$target" ]]; then
    return 0
  fi
  local backup="${target}$(date +${DATE_FMT})"
  cp -a "$target" "$backup"
  remove_sockets_from_backup "$backup"
  ok "已备份到 $backup"
}

# ---------- 仓库初始化 ----------
ensure_repo_exists() {
  local auto="${1:-false}"
  local repo
  repo=$(repo_root)
  if [[ -d "${repo}/.git" ]]; then
    return 0
  fi

  if [[ "$auto" == "true" ]]; then
    mkdir -p "$DOTMAN_HOME"
    git init "$repo" > /dev/null
    mkdir -p "$DOTMAN_CONFIG_DIR"

    local host
    host=$(hostname -s)
    cat > "${DOTMAN_CONFIG_DIR}/${CONFIG_FILE}" <<EOF
repo_path = "${repo}"
hostname = "${host}"
EOF
    cat > "${repo}/${CONFIG_FILE}" <<EOF
repo_url = ""
EOF
    ini_ensure_links_file "${repo}/${LINKS_COMMON}"
    git -C "$repo" add -A
    git -C "$repo" commit -m "dotman init" > /dev/null 2>&1 || true
    ok "仓库初始化完成：${repo}"
    return 0
  fi

  echo ""
  warn "未找到 dotman 仓库：${repo}"
  info "工作目录：${DOTMAN_HOME}"
  echo ""
  read -rp "是否立即初始化新仓库？ [Y/n] " answer
  case "${answer:-Y}" in
    [yY]|[yY][eE][sS])
      ensure_repo_exists true
      ;;
    *)
      info "已取消初始化。你可以稍后运行：dotman init <git-url>"
      exit 0
      ;;
  esac
}

# ---------- ASCII Logo ----------
print_logo() {
  echo "${C_BLUE}${C_BOLD}"
  cat <<'EOF'
 ____  ____  _____  _      ____  _
/  _ \/  _ \/__ __\/ \__/|/  _ \/ \  /|
| | \|| / \|  / \  | |\/||| / \|| |\ ||
| |_/|| \_/|  | |  | |  ||| |-||| | \||
\____/\____/  \_/  \_/  \|\_/ \|\_/  \|
EOF
  echo "${C_RESET}"
  echo "${C_CYAN}自用 dotfiles 管理器${C_RESET} | 版本 ${VERSION}"
  echo ""
}

# ---------- 命令实现 ----------
cmd_init() {
  local url="${1:-}"
  if [[ -z "$url" ]]; then
    err "用法: dotman init <git-url>"
    exit 1
  fi
  local repo
  repo=$(repo_root)

  mkdir -p "$DOTMAN_HOME"

  if [[ -d "$repo" ]]; then
    if [[ -d "$repo/.git" ]]; then
      warn "目录已存在 git 仓库，将使用现有仓库"
    else
      err "目录已存在但非 git 仓库: $repo"
      exit 1
    fi
  else
    git clone "$url" "$repo"
  fi

  mkdir -p "$DOTMAN_CONFIG_DIR"
  local host
  host=$(hostname -s)
  cat > "${DOTMAN_CONFIG_DIR}/${CONFIG_FILE}" <<EOF
repo_path = "${repo}"
hostname = "${host}"
EOF

  local cfg="${repo}/${CONFIG_FILE}"
  if [[ -f "$cfg" ]]; then
    local cur_url
    cur_url=$(ini_get_value "$cfg" "" "repo_url")
    if [[ -z "$cur_url" ]]; then
      ini_set_value "$cfg" "" "repo_url" "$url"
    fi
  else
    cat > "$cfg" <<EOF
repo_url = "${url}"
EOF
  fi

  ini_ensure_links_file "${repo}/${LINKS_COMMON}"

  ok "初始化完成：$repo"
  info "当前设备名：$(current_hostname)"
}

cmd_pull() {
  ensure_repo_exists
  git_dot pull
  ok "拉取完成"
}

cmd_push() {
  ensure_repo_exists
  local msg="${1:-dotman update}"
  auto_commit_push "$msg"
  ok "推送完成"
}

# 单个文件/目录添加的核心逻辑（不提交）
# 成功返回 0，失败返回 1
add_one_item() {
  local src="$1" dst="${2:-}"

  if is_ssh_private_key "$src"; then
    err "检测到 SSH 私钥，拒绝加入仓库: $src"
    info "Git 无法保留 600 权限，checkout 后权限会变松，导致 SSH 无法使用"
    info "私钥也不应明文存入 Git 历史"
    info "如需同步，请使用密码管理器、加密存储或手动安全复制"
    return 1
  fi

  if [[ "$src" == "$HOME/.ssh/"* ]] && ! is_safe_ssh_file "$src"; then
    warn "该文件位于 ~/.ssh 目录且不属于推荐同步的安全文件类型"
    info "推荐同步：config、known_hosts、authorized_keys、*.pub"
    info "请确认你确实希望将其加入仓库"
  fi

  if [[ -z "$dst" ]]; then
    dst="$src"
  else
    dst=$(expand_path "$dst")
  fi

  local rel
  rel=$(home_relative_path "$src")
  if [[ -z "$rel" ]]; then
    err "源路径不在 HOME 目录内，请改用：dotman link <仓库内路径> <${src}>"
    return 1
  fi

  local repo
  repo=$(repo_root)
  local repo_path="${repo}/${rel}"

  if [[ "$src" == "$repo" || "$src" == "$repo/"* ]]; then
    err "源路径已经在仓库内，无需 add"
    return 1
  fi

  ensure_parent "$repo_path"
  if [[ -e "$repo_path" || -L "$repo_path" ]]; then
    if [[ -t 0 ]]; then
      warn "仓库中已存在同名文件/目录: $rel"
      echo "  ${C_GREEN}1${C_RESET}. 用本地版本覆盖仓库版本（默认）"
      echo "  ${C_CYAN}2${C_RESET}. 保留仓库版本，备份本地版本并创建软链"
      echo "  ${C_RED}3${C_RESET}. 取消"
      local choice
      read -rp "请选择 [1/2/3]: " choice
      case "${choice:-1}" in
        1)
          backup_item "$repo_path"
          rm -rf "$repo_path"
          mv "$src" "$repo_path"
          ;;
        2)
          backup_item "$src"
          rm -rf "$src"
          ;;
        3|*)
          info "已取消"
          return 1
          ;;
      esac
    else
      warn "仓库中已存在 ${rel}，非交互模式默认用本地版本覆盖"
      backup_item "$repo_path"
      rm -rf "$repo_path"
      mv "$src" "$repo_path"
    fi
  else
    mv "$src" "$repo_path"
  fi

  make_link "$repo_path" "$dst"

  local host
  host=$(current_hostname)
  local links_file="${repo}/${LINKS_PREFIX}${host}.conf"
  ini_add_link "$links_file" "$rel" "$(relative_home "$dst")"

  ok "已添加并链接：$rel -> $dst"
  return 0
}

interactive_add_directory() {
  local dir="$1"
  local is_ssh=false
  if [[ "$(basename "$dir")" == ".ssh" ]]; then
    is_ssh=true
    warn ".ssh 目录中包含私钥文件，无法按目录添加。"
  else
    warn "检测到 $(basename "$dir") 目录中包含二进制/日志/数据文件，不适合整体添加。"
  fi

  local answer
  read -rp "是否改为逐个文件添加？ [Y/n] " answer
  case "${answer:-Y}" in
    [yY]|[yY][eE][sS]) ;;
    *)
      info "已取消"
      return 0
      ;;
  esac

  local items=()
  local managed_flags=()
  local type_labels=()
  local item
  while IFS= read -r -d '' item; do
    if [[ "$is_ssh" == "true" ]] && is_ssh_private_key "$item"; then
      continue
    fi
    items+=("$item")
    if is_managed_by_dotman "$item"; then
      managed_flags+=("1")
    else
      managed_flags+=("0")
    fi
    if [[ "$is_ssh" == "true" ]]; then
      type_labels+=("文本")
    else
      type_labels+=("$(file_type_label "$item")")
    fi
  done < <(find "$dir" -mindepth 1 -maxdepth 1 ! -name ".*" -print0 | sort -z)

  local total=${#items[@]}
  if [[ $total -eq 0 ]]; then
    info "目录中没有可添加的文件"
    return 0
  fi

  echo ""
  if [[ "$is_ssh" == "true" ]]; then
    info ".ssh 中的安全文件如下（私钥已过滤）："
  else
    info "目录中的文件如下（二进制/日志已标注）："
  fi
  echo ""

  local i
  for ((i=0; i<total; i++)); do
    local name
    name=$(basename "${items[$i]}")
    local managed_label
    local type_label="${type_labels[$i]}"
    local type_color="${C_CYAN}"
    local not_recommended=""

    if [[ "${managed_flags[$i]}" == "1" ]]; then
      managed_label="${C_GREEN}[已添加]${C_RESET}"
    else
      managed_label="${C_CYAN}[未添加]${C_RESET}"
    fi

    if [[ "$type_label" == "二进制" || "$type_label" == "含二进制" ]]; then
      type_color="${C_RED}"
      not_recommended=" ${C_YELLOW}(不建议)${C_RESET}"
    elif [[ "$type_label" == "日志" ]]; then
      type_color="${C_YELLOW}"
      not_recommended=" ${C_YELLOW}(不建议)${C_RESET}"
    fi

    printf "  %s%2d.%s %s %s%-6s%s   %s%s\n" \
      "${C_BOLD}" "$((i+1))" "${C_RESET}" \
      "$managed_label" "$type_color" "[$type_label]" "${C_RESET}" \
      "$name" "$not_recommended"
  done
  echo ""

  local selection
  read -rp "请输入要添加的序号（逗号分隔，a 添加全部推荐项，回车取消）: " selection
  selection=$(echo "$selection" | tr -d ' ')
  if [[ -z "$selection" || "$selection" == "q" ]]; then
    info "已取消"
    return 0
  fi

  local -a selected=()
  if [[ "$selection" == "a" ]]; then
    for ((i=0; i<total; i++)); do
      if [[ "${managed_flags[$i]}" == "0" ]] && [[ "${type_labels[$i]}" == "文本" || "${type_labels[$i]}" == "目录" ]]; then
        selected+=("${items[$i]}")
      fi
    done
  else
    local -a nums
    IFS=',' read -ra nums <<< "$selection"
    local n
    for n in "${nums[@]}"; do
      if [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= total )); then
        local idx=$((n-1))
        if [[ "${managed_flags[$idx]}" == "1" ]]; then
          warn "已跳过已添加项：$(basename "${items[$idx]}")"
        else
          selected+=("${items[$idx]}")
        fi
      else
        warn "无效序号，已忽略: $n"
      fi
    done
  fi

  if [[ ${#selected[@]} -eq 0 ]]; then
    info "没有选中新文件，无需处理"
    return 0
  fi

  # 对未选中且未管理的二进制/日志文件，询问是否加入 .gitignore
  local ignored_count=0
  if [[ "$is_ssh" != "true" ]]; then
    for ((i=0; i<total; i++)); do
      local found=false
      local sel
      for sel in "${selected[@]}"; do
        if [[ "$sel" == "${items[$i]}" ]]; then
          found=true
          break
        fi
      done
      if [[ "$found" == "false" ]] && [[ "${managed_flags[$i]}" == "0" ]] && [[ "${type_labels[$i]}" != "文本" && "${type_labels[$i]}" != "目录" ]]; then
        local rel_pattern
        rel_pattern=$(home_relative_path "${items[$i]}")
        add_to_gitignore "$rel_pattern"
        ignored_count=$((ignored_count + 1))
      fi
    done
  fi

  local success=0
  local item_path
  for item_path in "${selected[@]}"; do
    if add_one_item "$item_path"; then
      success=$((success + 1))
    else
      warn "添加失败：$item_path"
    fi
  done

  if [[ $ignored_count -gt 0 ]]; then
    warn "已自动忽略 ${ignored_count} 个二进制/日志文件"
  fi

  if [[ $success -gt 0 ]]; then
    auto_commit_push "dotman add batch from $(basename "$dir") (${success} items)"
    ok "共提交 ${success} 个文件"
  else
    info "没有成功添加的文件"
  fi
}

cmd_add() {
  ensure_repo_exists
  local src="${1:-}" dst="${2:-}"
  if [[ -z "$src" ]]; then
    err "用法: dotman add <本机路径> [目标软链路径]"
    exit 1
  fi
  src=$(expand_path "$src")
  if [[ ! -e "$src" && ! -L "$src" ]]; then
    err "源路径不存在: $src"
    exit 1
  fi
  if is_symlink "$src"; then
    err "源路径已是软链，无需 add: $src"
    info "如需更新内容，请直接编辑该软链指向的仓库文件"
    info "如需重新建立链接，请用：dotman link <仓库内路径> <${src}>"
    exit 1
  fi

  # .ssh 目录特殊处理
  if [[ "$(basename "$src")" == ".ssh" && -d "$src" ]]; then
    if [[ -t 0 ]]; then
      interactive_add_directory "$src"
      return 0
    else
      err "不建议将整个 ~/.ssh 目录加入 dotman 管理"
      info "原因："
      info "  1. Git 不保留 600 权限，私钥 checkout 后会变成 644，导致 SSH 拒绝连接"
      info "  2. 私钥以明文形式进入 Git 历史，存在安全风险"
      info "  3. .ssh 目录包含 agent socket、临时文件，不适合整体同步"
      info "建议单独添加安全文件："
      info "  dotman add ~/.ssh/config"
      info "  dotman add ~/.ssh/known_hosts"
      info "  dotman add ~/.ssh/authorized_keys"
      info "  dotman add ~/.ssh/id_ed25519.pub"
      info "私钥请使用密码管理器、加密存储或手动安全复制同步"
      exit 1
    fi
  fi

  # 二进制/日志文件检测
  if [[ -f "$src" ]]; then
    if is_binary_file "$src" || is_log_file "$src"; then
      local kind
      if is_binary_file "$src"; then
        kind="二进制文件"
      else
        kind="日志文件"
      fi
      warn "检测到 $(basename "$src") 是${kind}，不适合纳入 Git 管理。"
      info "此类文件在多设备同步时容易产生冲突，建议加入 .gitignore。"
      if [[ -t 0 ]]; then
        local answer
        read -rp "是否加入 .gitignore 并跳过添加？ [Y/n] " answer
        case "${answer:-Y}" in
          [yY]|[yY][eE][sS])
            add_to_gitignore "$(home_relative_path "$src")"
            return 0
            ;;
          *)
            warn "继续添加${kind}，如后续出现冲突请手动处理"
            ;;
        esac
      else
        err "非交互模式下不自动添加${kind}，如需添加请先用 dotman add 逐个处理"
        exit 1
      fi
    fi
  elif [[ -d "$src" ]]; then
    local binaries
    binaries=$(scan_binary_files "$src")
    if [[ -n "$binaries" ]]; then
      warn "检测到 $(basename "$src") 目录中包含二进制/日志/数据文件："
      local b
      while IFS= read -r b; do
        info "  $(relative_home "$b" 2>/dev/null || echo "$b")"
      done <<< "$binaries"
      info "此类文件不适合整体纳入 Git 管理，可能在多设备同步时产生冲突。"
      if [[ -t 0 ]]; then
        interactive_add_directory "$src"
        return 0
      else
        err "非交互模式下无法整体添加包含二进制文件的目录，请逐个添加文本文件"
        exit 1
      fi
    fi
  fi

  if add_one_item "$src" "$dst"; then
    auto_commit_push "dotman add $(basename "$src")"
  fi
}

cmd_remove() {
  ensure_repo_exists
  local dst="${1:-}"
  if [[ -z "$dst" ]]; then
    err "用法: dotman remove <目标软链路径>"
    exit 1
  fi
  dst=$(expand_path "$dst")

  local repo
  repo=$(repo_root)
  local host
  host=$(current_hostname)
  local rel_dst
  rel_dst=$(relative_home "$dst")

  local src
  src=$(ini_find_src_by_dst "$repo" "$host" "$rel_dst")
  if [[ -z "$src" ]]; then
    err "未找到目标链接: $dst"
    exit 1
  fi

  local repo_path="${repo}/${src}"

  if is_symlink "$dst"; then
    rm "$dst"
  elif [[ -e "$dst" || -L "$dst" ]]; then
    backup_item "$dst"
    rm -rf "$dst"
  fi

  if [[ -e "$repo_path" || -L "$repo_path" ]]; then
    cp -a "$repo_path" "$dst"
    rm -rf "$repo_path"
  fi

  ini_delete_by_dst "$repo" "$host" "$rel_dst"

  auto_commit_push "dotman remove $rel_dst"
  ok "已移除：$dst"
}

cmd_link() {
  ensure_repo_exists
  local src="${1:-}" dst="${2:-}"
  if [[ -z "$src" || -z "$dst" ]]; then
    err "用法: dotman link <仓库内相对路径> <本机目标路径>"
    exit 1
  fi

  local repo
  repo=$(repo_root)
  local repo_path="${repo}/${src}"
  dst=$(expand_path "$dst")

  if [[ ! -e "$repo_path" && ! -L "$repo_path" ]]; then
    err "仓库内不存在: $repo_path"
    exit 1
  fi

  if [[ -e "$dst" || -L "$dst" ]]; then
    backup_item "$dst"
    rm -rf "$dst"
  fi
  make_link "$repo_path" "$dst"

  local host
  host=$(current_hostname)
  local links_file="${repo}/${LINKS_PREFIX}${host}.conf"
  ini_add_link "$links_file" "$src" "$(relative_home "$dst")"

  auto_commit_push "dotman link $src"
  ok "已建立链接：$src -> $dst"
}

cmd_unlink() {
  ensure_repo_exists
  local dst="${1:-}"
  if [[ -z "$dst" ]]; then
    err "用法: dotman unlink <本机目标路径>"
    exit 1
  fi
  dst=$(expand_path "$dst")

  if is_symlink "$dst"; then
    rm "$dst"
  elif [[ -e "$dst" ]]; then
    warn "$dst 不是软链，不会删除真实文件"
  else
    warn "$dst 不存在"
  fi

  local repo
  repo=$(repo_root)
  local host
  host=$(current_hostname)
  local rel_dst
  rel_dst=$(relative_home "$dst")

  ini_delete_by_dst "$repo" "$host" "$rel_dst"

  auto_commit_push "dotman unlink $rel_dst"
  ok "已解除链接：$dst"
}

cmd_status() {
  ensure_repo_exists
  local repo
  repo=$(repo_root)
  local host
  host=$(current_hostname)
  local total=0 ok_count=0 bad_count=0 missing_count=0

  info "设备名：$host"
  info "仓库：$repo"
  echo ""

  while IFS=$'\t' read -r src dst; do
    [[ -z "$src" ]] && continue
    total=$((total + 1))
    local repo_path="${repo}/${src}"
    local real_dst
    real_dst=$(expand_path "$dst")

    printf "%-36s -> %s\n" "$src" "$dst"

    if [[ ! -e "$real_dst" && ! -L "$real_dst" ]]; then
      echo "  ${C_RED}缺失${C_RESET} 目标不存在"
      missing_count=$((missing_count + 1))
    elif ! is_symlink "$real_dst"; then
      echo "  ${C_YELLOW}冲突${C_RESET} 目标存在但不是软链"
      bad_count=$((bad_count + 1))
    elif ! [[ -e "$repo_path" || -L "$repo_path" ]]; then
      echo "  ${C_RED}仓库缺失${C_RESET} 仓库源文件不存在: $repo_path"
      bad_count=$((bad_count + 1))
    elif symlink_points_to "$real_dst" "$repo_path"; then
      echo "  ${C_GREEN}正常${C_RESET}"
      ok_count=$((ok_count + 1))
    else
      local real
      real=$(readlink "$real_dst")
      echo "  ${C_YELLOW}指向错误${C_RESET} 当前指向: $real"
      bad_count=$((bad_count + 1))
    fi
  done < <(ini_load_links "$repo" "$host")

  echo ""
  info "总计: $total | 正常: $ok_count | 异常: $bad_count | 缺失: $missing_count"
}

cmd_fix() {
  ensure_repo_exists
  local repo
  repo=$(repo_root)
  local fixed=0
  local host
  host=$(current_hostname)

  while IFS=$'\t' read -r src dst; do
    [[ -z "$src" ]] && continue
    local repo_path="${repo}/${src}"
    local real_dst
    real_dst=$(expand_path "$dst")

    if is_symlink "$real_dst" && symlink_points_to "$real_dst" "$repo_path"; then
      fix_link_permissions "$repo_path" "$real_dst"
      continue
    fi

    if [[ -e "$real_dst" || -L "$real_dst" ]]; then
      backup_item "$real_dst"
      rm -rf "$real_dst"
    fi

    make_link "$repo_path" "$real_dst"
    ok "已修复：$dst"
    fixed=$((fixed + 1))
  done < <(ini_load_links "$repo" "$host")

  if [[ $fixed -eq 0 ]]; then
    info "所有链接均正常"
  else
    ok "共修复 $fixed 个链接"
  fi
}

cmd_doctor() {
  ensure_repo_exists
  local repo
  repo=$(repo_root)
  info "检查仓库..."
  git_dot status --short

  info "检查链接..."
  cmd_status

  info "检查未提交改动..."
  if [[ -z "$(git_dot status --porcelain)" ]]; then
    ok "仓库干净"
  else
    warn "仓库有未提交改动，可运行 dotman push 提交"
  fi
}


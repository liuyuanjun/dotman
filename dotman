# ---------- 交互式界面 ----------
interactive_read_path() {
  local prompt="$1"
  local value
  read -rp "$prompt" value
  # 去掉首尾空白
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  echo "$value"
}

# 展示当前管理的链接列表，设置全局变量 INTERACTIVE_SELECTED_LINK
interactive_select_link() {
  local repo="$1" host="$2"
  local -a entries=()
  local idx=0
  local src dst

  INTERACTIVE_SELECTED_LINK=""

  while IFS=$'\t' read -r src dst; do
    [[ -z "$src" ]] && continue
    idx=$((idx + 1))
    entries+=("$dst")
    printf "  ${C_GREEN}%2d${C_RESET}. %-40s (%s)\n" "$idx" "$dst" "$src"
  done < <(ini_load_links "$repo" "$host")

  if [[ ${#entries[@]} -eq 0 ]]; then
    echo ""
    warn "当前没有管理的链接"
    return 1
  fi

  echo ""
  local choice
  read -rp "请选择要操作的序号 [1-$idx] (直接回车取消): " choice
  if [[ -z "$choice" ]]; then
    return 1
  fi
  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= idx )); then
    INTERACTIVE_SELECTED_LINK="${entries[$((choice - 1))]}"
    return 0
  else
    err "无效选择"
    return 1
  fi
}

interactive_ensure_repo() {
  while true; do
    clear 2>/dev/null || true
    print_logo
    warn "仓库尚未初始化"
    echo ""
    echo "${C_BOLD}操作菜单：${C_RESET}"
    echo "  ${C_GREEN}1${C_RESET}. 初始化/克隆远程仓库        dotman init <git-url>"
    echo "  ${C_GREEN}2${C_RESET}. 创建本地空仓库            （自动初始化）"
    echo "  ${C_RED}0${C_RESET}. 退出"
    echo ""

    local choice
    read -rp "请选择操作 [0-2]: " choice
    case "$choice" in
      1)
        local url
        url=$(interactive_read_path "请输入 Git 仓库地址: ")
        if [[ -n "$url" ]]; then
          cmd_init "$url"
          return 0
        fi
        ;;
      2)
        ensure_repo_exists true
        return 0
        ;;
      0|q|quit|exit) exit 0 ;;
      *) err "无效选择" ;;
    esac
    read -rp "按回车键继续..."
  done
}

interactive_menu() {
  while true; do
    clear 2>/dev/null || true
    print_logo

    local repo
    repo=$(repo_root)
    echo "${C_BOLD}设备：${C_RESET}$(current_hostname)   ${C_BOLD}仓库：${C_RESET}${repo}"
    echo ""
    cmd_status 2>/dev/null || true

    echo ""
    echo "${C_BOLD}操作菜单：${C_RESET}"
    echo "  ${C_GREEN}1${C_RESET}. 初始化/克隆远程仓库        dotman init <git-url>"
    echo "  ${C_GREEN}2${C_RESET}. 拉取远程更新               dotman pull"
    echo "  ${C_GREEN}3${C_RESET}. 推送本地改动               dotman push [message]"
    echo "  ${C_GREEN}4${C_RESET}. 添加本机文件到仓库         dotman add <src> [dst]"
    echo "  ${C_GREEN}5${C_RESET}. 移除并恢复文件             dotman remove"
    echo "  ${C_GREEN}6${C_RESET}. 检查链接状态               dotman status"
    echo "  ${C_GREEN}7${C_RESET}. 一键修复链接               dotman fix"
    echo "  ${C_GREEN}8${C_RESET}. 综合诊断                  dotman doctor"
    echo "  ${C_RED}0${C_RESET}. 退出"
    echo ""

    local choice
    read -rp "请选择操作 [0-8]: " choice

    case "$choice" in
      1)
        local url
        url=$(interactive_read_path "请输入 Git 仓库地址: ")
        if [[ -n "$url" ]]; then cmd_init "$url"; fi ;;
      2) cmd_pull ;;
      3)
        local msg
        msg=$(interactive_read_path "请输入提交消息（直接回车使用默认）: ")
        if [[ -n "$msg" ]]; then cmd_push "$msg"; else cmd_push; fi ;;
      4)
        local src dst
        src=$(interactive_read_path "请输入要添加的本机路径: ")
        dst=$(interactive_read_path "请输入目标软链路径（直接回车与源路径相同）: ")
        if [[ -n "$src" ]]; then
          if [[ -n "$dst" ]]; then cmd_add "$src" "$dst"; else cmd_add "$src"; fi
        fi ;;
      5)
        echo ""
        info "当前管理的链接列表："
        if interactive_select_link "$repo" "$(current_hostname)"; then
          cmd_remove "$INTERACTIVE_SELECTED_LINK"
        fi ;;
      6) cmd_status ;;
      7) cmd_fix ;;
      8) cmd_doctor ;;
      0|q|quit|exit) exit 0 ;;
      *) err "无效选择，请重新输入" ;;
    esac

    echo ""
    read -rp "按回车键继续..."
  done
}

# ---------- 入口 ----------
main() {
  check_deps

  if [[ $# -eq 0 ]]; then
    if repo_has_git; then
      # 交互式启动时先尝试拉取远程更新
      if [[ -n "$(git_dot remote)" ]]; then
        info "正在拉取远程更新..."
        if ! git_dot pull 2>/dev/null; then
          warn "拉取失败，将继续使用本地仓库"
        fi
      fi
      interactive_menu
    else
      interactive_ensure_repo
      interactive_menu
    fi
    return 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    init)    cmd_init "$@" ;;
    pull)    cmd_pull ;;
    push)    cmd_push "$@" ;;
    add)     cmd_add "$@" ;;
    remove)  cmd_remove "$@" ;;
    link)    cmd_link "$@" ;;
    unlink)  cmd_unlink "$@" ;;
    status)  cmd_status ;;
    fix)     cmd_fix ;;
    doctor)  cmd_doctor ;;
    help|--help|-h) cmd_help ;;
    *)       err "未知命令: $cmd"; cmd_help; exit 1 ;;
  esac
}

main "$@"
